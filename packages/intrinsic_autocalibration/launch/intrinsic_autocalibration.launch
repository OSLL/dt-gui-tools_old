<?xml version="1.0"?>

<launch>
	<arg name="veh" default="$(env VEHICLE_NAME)"/>
	<group ns="$(arg veh)">
		<remap from="intrinsic_autocalibration/wheels_cmd" to="wheels_driver_node/wheels_cmd"/>
		<remap from="intrinsic_autocalibration/image/compressed" to="camera_node/image/compressed"/>
		<node name="intrinsic_autocalibration" pkg="intrinsic_autocalibration" type="intrinsic_autocalibration.py" output="screen" required="true"/>
	</group>
</launch>