<?xml version="1.0"?>

<launch>
	<arg name="veh" default="$(env VEHICLE_NAME)"/>
	<group ns="$(arg veh)">
		<remap from="extrinsic_autocalibration/wheels_cmd" to="wheels_driver_node/wheels_cmd"/>
		<remap from="extrinsic_autocalibration/image/compressed" to="camera_node/image/compressed"/>
		<node name="extrinsic_autocalibration" pkg="extrinsic_autocalibration" type="extrinsic_autocalibration.py" output="screen" required="true"/>
	</group>
</launch>